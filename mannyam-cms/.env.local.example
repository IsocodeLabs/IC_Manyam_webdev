# MANNYAM Studio CMS Environment Variables Template
# Copy this file to .env.local and populate with the actual values.

# Supabase Configuration
# The production database is located at https://api.mannyam.in
NEXT_PUBLIC_SUPABASE_URL=https://api.mannyam.in
NEXT_PUBLIC_SUPABASE_ANON_KEY=placeholder-anon-key
SUPABASE_SERVICE_ROLE_KEY=placeholder-service-role-key

# Secret accepted as either `Authorization: Bearer <value>` or `X-Cron-Secret`.
CRON_SECRET=replace-with-a-long-random-secret

# Public site URL used for sitemap generation and canonical links
NEXT_PUBLIC_SITE_URL=https://mannyam.in
